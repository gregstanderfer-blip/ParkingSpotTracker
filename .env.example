# Blink account login (the same email/password you use in the Blink app)
BLINK_USERNAME=you@example.com
BLINK_PASSWORD=your-blink-password

# Where to send iMessage alerts — your phone number (+15551234567) or Apple ID email.
# Tip: use a number/address you can iMessage yourself at.
IMESSAGE_RECIPIENT=+15551234567
